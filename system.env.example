# System-level environment variables for RAS workflow runner
# These are shared across all users and environments; do not include secrets here
# Copy to your local system.env file and adjust for your environment

# ==================== RAS OAuth Endpoints ====================
# Base URL for RAS (staging environment shown; use production for real workflows)
RAS_BASE_URL=https://stsstg.nih.gov

# OAuth endpoints (these are the defaults; only override if needed)
RAS_AUTHORIZE_PATH=/auth/oauth/v2/authorize
RAS_TOKEN_PATH=/auth/oauth/v2/token
RAS_USERINFO_PATH=/openid/connect/v1.1/userinfo
RAS_USERINFO_METHOD=POST
RAS_VALIDATE_PATH=/passport/validate

# ==================== OAuth Client Configuration ====================
# OAuth client ID for the CTDC application (shared across all testers)
RAS_CLIENT_ID=b0714287-43ee-479f-b151-8e58f3622899

# OAuth client secret (KEEP PRIVATE - do not commit to version control)
RAS_CLIENT_SECRET=your-client-secret-here

# OAuth scopes to request (includes ga4gh_passport_v1 for Passport/Visa claims)
RAS_SCOPE=openid profile email ga4gh_passport_v1

# Redirect URI configured in the OAuth application
CTDC_REDIRECT_URI=https://clinical-dev.datacommons.cancer.gov/api/auth/callback

# ==================== Browser & HTTP Settings ====================
# Set to false to see the browser window during automation (recommended for debugging)
# Set to true to run headless (for CI/CD pipelines)
HEADLESS=false

# Timeout (ms) for page navigation and element interactions
BROWSER_TIMEOUT_MS=180000

# Timeout (ms) for HTTP API calls
HTTP_TIMEOUT_MS=30000
