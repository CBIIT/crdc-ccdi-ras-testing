# Copy this file to your user-specific .env (e.g., yizhen.chen.env) and populate with your credentials.
# Never commit credentials to version control.

# ==================== Identity Provider Selection ====================
# Supported values: id.me, login.gov
# This determines which sign-in flow will be used in step 1 (authorize-login)
IDP=id.me

# ==================== Login Credentials ====================
# Used for both id.me and login.gov sign-in
EMAIL=your-email@example.com
PASSWORD=your-password

# Multi-factor authentication (MFA) code (optional - only set if you want to pre-fill the code)
# Used for both id.me and login.gov
MFA_CODE=

# ==================== Pre-captured Tokens ====================
# Set these to skip step 1 and run steps 2+ directly (useful for testing individual steps)
AUTHORIZATION_CODE=
ACCESS_TOKEN=
REFRESH_TOKEN=
ID_TOKEN=

# ==================== DRS Test Fixtures ====================
# Required for step 6 (request-drs-access)
# URL of an object your account is authorized to access
DRS_ACCESS_URL=
DCF_DRS_ACCESS_URL=
AUTHORIZED_DRS_URL=

# ==================== No-Access Test Fixtures ====================
# Used for test case 03c (open-access-without-visas)
# User token with no access to controlled data
NO_ACCESS_ACCESS_TOKEN=

# URL to an open-access object (no authorization required)
NO_ACCESS_OPEN_DATA_URL=

# URL to a controlled object the user cannot access
NO_ACCESS_CONTROLLED_DRS_URL=

# ==================== Browser & HTTP Settings ====================
# Set to true to run browser in headless mode; false to see the browser window during sign-in
HEADLESS=false

# Timeout (ms) for page navigation and element interactions in Playwright
BROWSER_TIMEOUT_MS=180000

# Timeout (ms) for HTTP requests
HTTP_TIMEOUT_MS=30000
